# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview

# Sanity CMS Configuration
SANITY_PROJECT_ID=your_sanity_project_id
SANITY_DATASET=production
SANITY_API_TOKEN=your_sanity_api_token
SANITY_API_VERSION=2024-01-01

# Pipeline Configuration
ARTICLES_PER_DAY=1
DEFAULT_SECTION=cannabis
# node-cron schedule for daemonServer (Render all-in-one). Default 14:00 daily. See https://crontab.guru
# PIPELINE_CRON=0 14 * * *

# Telegram (on-demand publishing)
# Create a bot via BotFather and paste token here
TELEGRAM_BOT_TOKEN=123456:abc-your-telegram-bot-token
# Restrict bot usage to your Telegram numeric user id
TELEGRAM_ALLOWED_USER_ID=123456789
# Public HTTPS origin only — no trailing slash (e.g. https://happytimesazpipeline.onrender.com)
TELEGRAM_WEBHOOK_BASE_URL=https://your-domain.com
# Random secret used in the webhook path to prevent abuse (webhook mode only)
TELEGRAM_WEBHOOK_PATH_SECRET=replace-with-a-long-random-string
# Optional: persist Telegram draft sessions across restarts (default: OS temp dir JSON file)
# TELEGRAM_SESSION_FILE=/data/happytimes-telegram-sessions.json
# Port to listen on (Render/Heroku/etc set PORT automatically)
PORT=3000

# REST API (daemon: GET /api/status, POST /api/command). Required for those routes.
# Send as header: X-API-Key: <value> or Authorization: Bearer <value>
API_KEY=replace-with-a-long-random-string
# POST /api/upload stores each image’s Sanity asset id in a per-session queue (max 5, FIFO).
# POST /api/upload-video (multipart field: video, max ~200MB) uploads a Sanity file asset; session keeps one draftVideoAssetId (replaced on each upload). Publish sets post.featuredVideo in Sanity.
# Session key: TELEGRAM_ALLOWED_USER_ID by default, or header X-Session-Chat-Id / X-Requester-Id (numeric).
# POST /api/command "/publish" with notes but no body images uses that queue (first = hero) — no DALL·E.
# - JSON: optional imageAssetIds (max 5) when embedding ids directly — first = hero.
# - multipart: optional "images" (max 5); if omitted, same session queue is used.

# Optional: comma-separated allowed browser origins for /api/* (no trailing slash).
# Use your Vercel dashboard URL(s), e.g. https://happytimesaz.vercel.app
# If unset, Access-Control-Allow-Origin is * (any origin).
# CORS_ORIGINS=https://your-app.vercel.app

# SerpApi — same key for Google Events (syncEvents) + Google News (syncNews) + Google Maps dispensaries (syncDispensaries / npm run sync-dispensaries)
SERPAPI_API_KEY=your_serpapi_key_here
# Optional: max SerpApi pagination offset per city for dispensary sync (default 100; Google Maps ~20 results per page)
# DISPENSARY_SERP_MAX_START=100
# Google Events: default Monday 08:00 weekly (server timezone). Max 50 events per run.
# SERPAPI_EVENTS_CRON=0 8 * * 1

# SerpApi Google News — daemon daily + POST /api/command syncNews (uses SERPAPI_API_KEY)
# Default 10:00 daily. Fetch up to 10 headlines; AI picks top 1–3 (score ≥7) to publish.
# GOOGLE_NEWS_CRON=0 10 * * *
# GOOGLE_NEWS_MAX_FETCH=10
# GOOGLE_NEWS_MAX_PUBLISH=3

# Daily: set isActive=false on past events in Sanity (separate from SerpApi sync)
# EVENTS_CLEANUP_CRON=0 1 * * *
