{
  "name": "happytimes-ai-pipeline",
  "version": "1.0.0",
  "description": "AI publishing pipeline for HappyTimesAZ.com - generates and publishes articles to Sanity CMS",
  "main": "dist/orchestrator.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/orchestrator.js",
    "dev": "ts-node orchestrator.ts",
    "type-check": "tsc --noEmit",
    "repair": "ts-node scripts/repairPortableText.ts",
    "cleanup-events": "ts-node scripts/cleanupEvents.ts",
    "sync-dispensaries": "ts-node scripts/syncDispensaries.ts",
    "fetch-restaurants": "ts-node scripts/fetchRestaurants.ts",
    "fetch-restaurants:node": "node scripts/fetchRestaurants.js",
    "pipeline": "npm run build && node dist/orchestrator.js",
    "telegram": "npm run build && node dist/telegramServer.js",
    "telegram:dev": "ts-node telegramServer.ts",
    "telegram:polling:dev": "ts-node telegramPollingDev.ts",
    "daemon": "npm run build && node dist/daemonServer.js",
    "daemon:dev": "ts-node daemonServer.ts"
  },
  "keywords": [
    "ai",
    "pipeline",
    "cms",
    "sanity",
    "publishing"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@sanity/client": "^6.15.0",
    "axios": "^1.6.2",
    "dotenv": "^16.3.1",
    "express": "^5.2.1",
    "form-data": "^4.0.5",
    "grammy": "^1.41.1",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.10.5",
    "@types/node-cron": "^3.0.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
